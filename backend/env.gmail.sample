# Google Cloud OAuth (Gmail API) — copy into .env
# 1. Enable "Gmail API" for your GCP project.
# 2. OAuth consent screen → add test users while in Testing.
# 3. Credentials → OAuth 2.0 Client ID (Web application)
# 4. Authorized redirect URI must match exactly:
GOOGLE_REDIRECT_URI=http://localhost:5001/api/gmail/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# After OAuth, user is sent back to the React app:
FRONTEND_URL=http://localhost:5173

# Optional: override Gmail search (default searches PDF attachments + statement keywords)
# GMAIL_SYNC_QUERY=has:attachment filename:pdf newer_than:30d
